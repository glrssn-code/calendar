{
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(taskkill /PID 26084 /F)",
      "Bash(cmd /c \"taskkill /PID 26084 /F\")",
      "Bash(cmd /c \"taskkill /IM node.exe /F\")",
      "Bash(cmd /c \"for /f \\\\\"tokens=5\\\\\" %a in \\('netstat -ano ^| findstr :3000 ^| findstr LISTENING'\\) do taskkill /PID %a /F\")",
      "Bash(npx kill-port:*)",
      "Bash(curl -X DELETE \"http://localhost:3000/.next/...\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(rm -rf .next)",
      "Bash(rm -rf node_modules/.cache)"
    ]
  }
}
